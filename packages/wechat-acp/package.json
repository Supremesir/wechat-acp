{
  "name": "wechat-acp",
  "version": "0.6.0",
  "description": "WeChat + ACP adapter — connect Cursor CLI / Claude Code / Codex to WeChat",
  "license": "MIT",
  "type": "module",
  "bin": {
    "wechat-acp": "dist/main.mjs"
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "wechat-feedback-server.cjs",
    "mcp-timeout-hook.cjs"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.26.0",
    "@agentclientprotocol/sdk": "^0.18.2",
    "@zed-industries/codex-acp": "^0.11.1",
    "cross-spawn": "^7.0.6",
    "wechat-sdk": "workspace:*"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm run build",
    "login": "tsx main.ts login",
    "start": "tsx main.ts start",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.0.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0"
  }
}
